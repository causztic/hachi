#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
RUNTIME_ROOT="${REPO_ROOT}/.hachi/bin/llama-server-cuda-linux/rootfs"
SERVER_BIN="${RUNTIME_ROOT}/app/llama-server"
CUDA_LIB_DIR="${RUNTIME_ROOT}/usr/local/cuda-12.8/targets/x86_64-linux/lib"

if [[ ! -x "${SERVER_BIN}" ]]; then
  echo "missing llama-server runtime at ${SERVER_BIN}" >&2
  exit 1
fi

# Keep the runtime's app and CUDA libraries ahead of the host path, but do not
# inject the container's system libc into the host process. That mix crashes
# immediately under WSL when the server boots.
export LD_LIBRARY_PATH="${CUDA_LIB_DIR}:${RUNTIME_ROOT}/app:/usr/lib/wsl/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
exec "${SERVER_BIN}" "$@"
